  </div>
</div>
<!-- ═══════════════════ EMERGENCY CONTACTS ═══ -->
<div id="screen-emergency" class="screen">
  <div class="sb"></div>
  <div class="topbar" style="padding-bottom:14px">
    <div class="topbar-row">
      <button class="back-btn" id="em-back-btn" onclick="goTo('screen-home')"><svg viewBox="0 0 24 24" fill="none"><polyline points="15 18 9 12 15 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></button>
      <div class="tbar-logo" style="padding:2px 0"><img id="em-logo" src="" alt="Slán Safety" style="height:44px;object-fit:contain;display:block"></div>
      <div style="width:36px"></div>
    </div>
    <div class="tbar-greeting" style="margin-top:10px">
      <h1>Emergency Contacts</h1>
      <p id="em-site">Site emergency contacts</p>
    </div>
  </div>

  <div class="tiles">

    <!-- CALL 000 -->
    <a href="tel:000" style="text-decoration:none;display:block;background:#B83232;border-radius:var(--r);padding:18px;text-align:center">
      <div style="font-size:24px;font-weight:700;color:#fff">📞 Call 000</div>
      <div style="font-size:12px;color:rgba(255,255,255,.8);margin-top:5px">Ambulance · Fire · Police — life-threatening emergencies only</div>
    </a>

    <!-- Site Supervisor -->
    <div class="fcard" style="padding:0">
      <div class="contact-row" onclick="callContact('supervisor')" style="border-bottom:none">
        <div class="contact-icon" style="background:#E6F5ED"><svg viewBox="0 0 24 24" fill="none" stroke="var(--mid)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:17px;height:17px"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
        <div class="contact-info"><div class="contact-name" id="em-sup-name">Site Supervisor</div><div class="contact-role" id="em-sup-phone">Tap to call</div></div>
        <div class="contact-call"><svg viewBox="0 0 24 24" fill="none" stroke="var(--mid)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.6 19.79 19.79 0 0 1 1.61 3 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
      </div>
    </div>

    <!-- Nearest Hospital / A&E -->
    <div class="fcard" style="padding:0">
      <div class="fcard-hdr" style="border-bottom:1px solid var(--border)">Nearest Hospital / Emergency Department</div>
      <div id="em-hospital-rows" style="padding:12px 14px;display:flex;flex-direction:column;gap:6px">
        <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 10px;align-items:start">
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Name</div>
          <div id="em-hosp-name" style="font-size:13px;font-weight:600;color:var(--text)">— Update with site-specific details —</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Address</div>
          <div id="em-hosp-addr" style="font-size:12px;color:var(--muted)">Contact Slán Safety to configure</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Hours</div>
          <div id="em-hosp-hours" style="font-size:12px;color:var(--muted)">24 / 7</div>
        </div>
        <a id="em-hosp-phone-link" href="tel:000" style="text-decoration:none;display:flex;align-items:center;justify-content:space-between;background:#FAEBEB;border:1.5px solid rgba(184,50,50,.2);border-radius:var(--rs);padding:10px 13px;margin-top:4px">
          <div>
            <div id="em-hosp-phone-txt" style="font-size:13px;font-weight:600;color:#B83232">Phone — see above</div>
            <div style="font-size:11px;color:var(--muted)">Nearest A&amp;E / Emergency Department</div>
          </div>
          <div style="font-size:10px;font-weight:700;color:#B83232;background:#fff;border:1.5px solid rgba(184,50,50,.3);border-radius:7px;padding:4px 10px">CALL</div>
        </a>
      </div>
    </div>

    <!-- GP / Medical Centre -->
    <div class="fcard" style="padding:0">
      <div class="fcard-hdr" style="border-bottom:1px solid var(--border)">GP / Medical Centre</div>
      <div style="padding:12px 14px;display:flex;flex-direction:column;gap:6px">
        <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 10px;align-items:start">
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Name</div>
          <div style="font-size:13px;font-weight:600;color:var(--text)">— Update with site-specific details —</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Address</div>
          <div style="font-size:12px;color:var(--muted)">Contact Slán Safety to configure</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Hours</div>
          <div style="font-size:12px;color:var(--muted)">Mon–Fri 8am–6pm</div>
        </div>
        <a href="tel:000" style="text-decoration:none;display:flex;align-items:center;justify-content:space-between;background:#E6EEF9;border:1.5px solid rgba(28,90,173,.2);border-radius:var(--rs);padding:10px 13px;margin-top:4px">
          <div>
            <div style="font-size:13px;font-weight:600;color:#1C5AAD">Phone — see above</div>
            <div style="font-size:11px;color:var(--muted)">GP / Medical Centre</div>
          </div>
          <div style="font-size:10px;font-weight:700;color:#1C5AAD;background:#fff;border:1.5px solid rgba(28,90,173,.3);border-radius:7px;padding:4px 10px">CALL</div>
        </a>
      </div>
    </div>

    <!-- Urgent Care -->
    <div class="fcard" style="padding:0">
      <div class="fcard-hdr" style="border-bottom:1px solid var(--border)">Urgent Care</div>
      <div style="padding:12px 14px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:10px;line-height:1.5">For non-life-threatening injuries — avoid A&amp;E queues</div>
        <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 10px;align-items:start;margin-bottom:8px">
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Name</div>
          <div style="font-size:13px;font-weight:600;color:var(--text)">— Update with site-specific details —</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Address</div>
          <div style="font-size:12px;color:var(--muted)">Contact Slán Safety to configure</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Hours</div>
          <div style="font-size:12px;color:var(--muted)">7 days — extended hours</div>
        </div>
        <a href="tel:000" style="text-decoration:none;display:flex;align-items:center;justify-content:space-between;background:#E6F5ED;border:1.5px solid rgba(45,106,69,.2);border-radius:var(--rs);padding:10px 13px">
          <div>
            <div style="font-size:13px;font-weight:600;color:var(--mid)">Phone — see above</div>
            <div style="font-size:11px;color:var(--muted)">Urgent Care Centre</div>
          </div>
          <div style="font-size:10px;font-weight:700;color:var(--mid);background:#fff;border:1.5px solid rgba(45,106,69,.3);border-radius:7px;padding:4px 10px">CALL</div>
        </a>
      </div>
    </div>

    <!-- After Hours & Physiotherapy -->
    <div class="fcard" style="padding:0">
      <div class="fcard-hdr" style="border-bottom:1px solid var(--border)">After Hours &amp; Physiotherapy</div>
      <div style="padding:12px 14px">
        <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 10px;align-items:start;margin-bottom:8px">
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Name</div>
          <div style="font-size:13px;font-weight:600;color:var(--text)">— Update with site-specific details —</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Address</div>
          <div style="font-size:12px;color:var(--muted)">Contact Slán Safety to configure</div>
          <div style="font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;padding-top:2px">Hours</div>
          <div style="font-size:12px;color:var(--muted)">Extended / after hours</div>
        </div>
        <a href="tel:000" style="text-decoration:none;display:flex;align-items:center;justify-content:space-between;background:#F3F0FB;border:1.5px solid rgba(91,33,182,.2);border-radius:var(--rs);padding:10px 13px">
          <div>
            <div style="font-size:13px;font-weight:600;color:#5B21B6">Phone — see above</div>
            <div style="font-size:11px;color:var(--muted)">After hours &amp; physio</div>
          </div>
          <div style="font-size:10px;font-weight:700;color:#5B21B6;background:#fff;border:1.5px solid rgba(91,33,182,.3);border-radius:7px;padding:4px 10px">CALL</div>
        </a>
      </div>
    </div>

    <!-- Other emergency numbers -->
    <div class="fcard">
      <div class="fcard-hdr">Other numbers</div>
      <div style="padding:0">
        <a href="tel:131444" class="contact-row" style="text-decoration:none;border-bottom:1px solid var(--border)">
          <div class="contact-icon" style="background:#E6EEF9"><svg viewBox="0 0 24 24" fill="none" stroke="#1C5AAD" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:17px;height:17px"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.6 19.79 19.79 0 0 1 1.61 3 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <div class="contact-info"><div class="contact-name">Police</div><div class="contact-role">131 444</div></div>
          <div class="contact-call" style="font-size:10px;font-weight:600;color:#1C5AAD;padding:4px 8px;background:#E6EEF9;border-color:rgba(28,90,173,.2);border-radius:8px">Call</div>
        </a>
        <a href="tel:131126" class="contact-row" style="text-decoration:none;border-bottom:1px solid var(--border)">
          <div class="contact-icon" style="background:#FDF2D8"><svg viewBox="0 0 24 24" fill="none" stroke="#906500" stroke-width="2" style="width:17px;height:17px"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/></svg></div>
          <div class="contact-info"><div class="contact-name">Poisons Information</div><div class="contact-role">13 11 26</div></div>
          <div class="contact-call" style="font-size:10px;font-weight:600;color:#906500;padding:4px 8px;background:#FDF2D8;border-color:rgba(144,101,0,.2);border-radius:8px">Call</div>
        </a>
        <a href="tel:13100307877" class="contact-row" style="text-decoration:none;border-bottom:1px solid var(--border)">
          <div class="contact-icon" style="background:#E6F5ED"><svg viewBox="0 0 24 24" fill="none" stroke="var(--mid)" stroke-width="2" style="width:17px;height:17px"><path d="M12 2L20 6L20 13C20 17.5 12 22 12 22C12 22 4 17.5 4 13L4 6Z"/><path d="M9 12l2 2 4-4"/></svg></div>
          <div class="contact-info"><div class="contact-name">SafeWork / WorkSafe</div><div class="contact-role">1300 307 877</div></div>
          <div class="contact-call" style="font-size:10px;font-weight:600;color:var(--mid);padding:4px 8px;background:#E6F5ED;border-color:rgba(45,106,69,.2);border-radius:8px">Call</div>
        </a>
        <a href="tel:131114" class="contact-row" style="text-decoration:none;border-bottom:1px solid var(--border)">
          <div class="contact-icon" style="background:#EDE9FE"><svg viewBox="0 0 24 24" fill="none" stroke="#5B21B6" stroke-width="2" style="width:17px;height:17px"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <div class="contact-info"><div class="contact-name">Lifeline</div><div class="contact-role">13 11 14 — 24/7 crisis support</div></div>
          <div class="contact-call" style="font-size:10px;font-weight:600;color:#5B21B6;padding:4px 8px;background:#EDE9FE;border-color:rgba(91,33,182,.2);border-radius:8px">Call</div>
        </a>
        <a href="tel:1800022222" class="contact-row" style="text-decoration:none;border-bottom:none">
          <div class="contact-icon" style="background:#E6EEF9"><svg viewBox="0 0 24 24" fill="none" stroke="#1C5AAD" stroke-width="2" style="width:17px;height:17px"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
          <div class="contact-info"><div class="contact-name">Healthdirect</div><div class="contact-role">1800 022 222 — health advice</div></div>
          <div class="contact-call" style="font-size:10px;font-weight:600;color:#1C5AAD;padding:4px 8px;background:#E6EEF9;border-color:rgba(28,90,173,.2);border-radius:8px">Call</div>
        </a>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════ MONTHLY SCORECARD ═══ -->
<div id="screen-scorecard" class="screen">
  <div class="sb"></div>
  <div class="topbar" style="padding-bottom:14px">
    <div class="topbar-row">
      <button class="back-btn" onclick="goToAnalytics('director')"><svg viewBox="0 0 24 24" fill="none"><polyline points="15 18 9 12 15 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></button>
      <div class="tbar-logo" style="padding:2px 0"><img id="sc-logo" src="" alt="Slán Safety" style="height:44px;object-fit:contain;display:block"></div>
      <div class="badge" style="background:rgba(184,150,12,.2);border-color:rgba(184,150,12,.4);color:rgba(184,150,12,.95);font-size:10px">Director</div>
    </div>
    <div class="tbar-greeting" style="margin-top:10px">
      <h1>Compliance Scorecard</h1>
      <p id="sc-period">April 2026 — Company Overview</p>
    </div>
    <!-- Month selector -->
    <div style="display:flex;gap:7px;margin-top:10px;flex-wrap:wrap">
      <div class="badge sc-month active-month" style="cursor:pointer;background:var(--gold);color:var(--deep);border-color:var(--gold)">Apr 2026</div>
      <div class="badge sc-month" style="cursor:pointer">Mar 2026</div>
      <div class="badge sc-month" style="cursor:pointer">Feb 2026</div>
      <div class="badge sc-month" style="cursor:pointer">Jan 2026</div>
    </div>
  </div>

  <div class="syncbar">
    <div class="sync-l"><div class="bdot g"></div><span>Auto-compiled from all registers</span></div>
    <div class="sync-r">April 2026</div>
  </div>

  <div class="tiles" style="padding-bottom:40px">

    <!-- Overall score -->
    <div style="background:var(--card);border-radius:var(--r);padding:16px;border:1px solid var(--border);text-align:center">
      <div style="font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px">Overall compliance score</div>
      <div style="font-size:52px;font-weight:600;color:#1B6E3A;line-height:1">87<span style="font-size:24px;color:var(--muted)">%</span></div>
      <div style="display:flex;justify-content:center;gap:16px;margin-top:12px">
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#1B6E3A"><span style="width:10px;height:10px;border-radius:50%;background:#1B6E3A"></span>14 Green</span>
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#B8960C"><span style="width:10px;height:10px;border-radius:50%;background:#B8960C"></span>3 Amber</span>
        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#B83232"><span style="width:10px;height:10px;border-radius:50%;background:#B83232"></span>1 Red</span>
      </div>
    </div>

    <!-- Scorecard items by category -->
    <div class="fcard">
      <div class="fcard" style="background:var(--deep);border:none;margin-bottom:0">
      <div class="fcard-body" style="flex-direction:row;align-items:center;justify-content:space-between;padding:14px 16px">
        <div>
          <div style="font-size:11px;font-weight:600;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px">Overall compliance</div>
          <div style="font-size:11px;color:rgba(255,255,255,.6)" id="sc-overall-status">April 2026 — Murphy Civil Construction</div>
        </div>
        <div style="font-size:38px;font-weight:700;color:var(--gold)" id="sc-overall-score">82%</div>
      </div>
    </div>
    <div class="fcard-hdr">Sign-in &amp; Attendance</div>
      <div class="fcard-body" style="gap:0;padding:0">
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Daily sign-in rate</div><div class="sc-val">98%</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Sign-out rate</div><div class="sc-val">97%</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Fitness for duty declarations</div><div class="sc-val">100%</div></div>
      </div>
    </div>

    <div class="fcard">
      <div class="fcard-hdr">Pre-starts &amp; Plant</div>
      <div class="fcard-body" style="gap:0;padding:0">
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Site pre-start completed daily</div><div class="sc-val">94%</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Plant pre-starts completed</div><div class="sc-val">91%</div></div>
        <div class="sc-row amber"><div class="sc-dot a"></div><div class="sc-label">Plant faults closed out</div><div class="sc-val">75% ⚠</div></div>
      </div>
    </div>

    <div class="fcard">
      <div class="fcard-hdr">Training &amp; Licences</div>
      <div class="fcard-body" style="gap:0;padding:0">
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">White Cards — current</div><div class="sc-val">100%</div></div>
        <div class="sc-row amber"><div class="sc-dot a"></div><div class="sc-label">HRWL compliance</div><div class="sc-val">88% ⚠</div></div>
        <div class="sc-row amber"><div class="sc-dot a"></div><div class="sc-label">Overall licence compliance</div><div class="sc-val">80% ⚠</div></div>
      </div>
    </div>

    <div class="fcard">
      <div class="fcard-hdr">Hazards &amp; Incidents</div>
      <div class="fcard-body" style="gap:0;padding:0">
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Hazards closed within 14 days</div><div class="sc-val">83%</div></div>
        <div class="sc-row red"><div class="sc-dot r"></div><div class="sc-label">Critical hazards resolved</div><div class="sc-val">67% ✕</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Incident reports submitted same day</div><div class="sc-val">100%</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Corrective actions on track</div><div class="sc-val">90%</div></div>
      </div>
    </div>

    <div class="fcard">
      <div class="fcard-hdr">Toolbox Talks &amp; SWMS</div>
      <div class="fcard-body" style="gap:0;padding:0">
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Monthly toolbox talk delivered</div><div class="sc-val">✓</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Worker sign-off rate</div><div class="sc-val">88%</div></div>
      </div>
    </div>

    <div class="fcard">
      <div class="fcard-hdr">Subcontractors &amp; Chemicals</div>
      <div class="fcard-body" style="gap:0;padding:0">
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Subcontractor insurance current</div><div class="sc-val">87%</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">SDS register current</div><div class="sc-val">92%</div></div>
        <div class="sc-row green"><div class="sc-dot g"></div><div class="sc-label">Chemical manifest up to date</div><div class="sc-val">✓</div></div>
      </div>
    </div>

    <!-- Action items -->
    <div class="fcard">
      <div class="fcard-hdr" style="background:#FAEBEB;color:#B83232">Action required this month</div>
      <div class="fcard-body" style="padding:12px 15px;gap:8px">
        <div style="display:flex;gap:8px;align-items:flex-start"><div style="width:6px;height:6px;border-radius:50%;background:#B83232;flex-shrink:0;margin-top:5px"></div><div style="font-size:12px;color:var(--text)">Resolve critical hazard — unsecured excavation Site A (overdue 3 days)</div></div>
        <div style="display:flex;gap:8px;align-items:flex-start"><div style="width:6px;height:6px;border-radius:50%;background:#B8960C;flex-shrink:0;margin-top:5px"></div><div style="font-size:12px;color:var(--text)">3 HRWL licences expiring within 30 days — arrange renewals</div></div>
        <div style="display:flex;gap:8px;align-items:flex-start"><div style="width:6px;height:6px;border-radius:50%;background:#B8960C;flex-shrink:0;margin-top:5px"></div><div style="font-size:12px;color:var(--text)">Close out 2 open plant faults — Excavator EX-02, Telehandler TH-01</div></div>
        <div style="display:flex;gap:8px;align-items:flex-start"><div style="width:6px;height:6px;border-radius:50%;background:#B8960C;flex-shrink:0;margin-top:5px"></div><div style="font-size:12px;color:var(--text)">3 workers have not signed this month's toolbox talk — Site C</div></div>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════ CORRECTIVE ACTIONS ═══ -->
<div id="screen-corrective-actions" class="screen">
  <div class="sb"></div>
  <div class="topbar" style="padding-bottom:14px">
    <div class="topbar-row">
      <button class="back-btn" onclick="goTo('screen-dash')"><svg viewBox="0 0 24 24" fill="none"><polyline points="15 18 9 12 15 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></button>
      <div class="tbar-logo" style="padding:2px 0"><img id="ca-logo" src="" alt="Slán Safety" style="height:44px;object-fit:contain;display:block"></div>
      <button onclick="openNewAction()" style="background:rgba(184,150,12,.2);border:1px solid rgba(184,150,12,.3);border-radius:9px;padding:6px 12px;color:var(--gold);font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">+ New</button>
    </div>
    <div class="tbar-greeting" style="margin-top:10px">
      <h1>Corrective Actions</h1>
      <p id="ca-subtitle">Open actions requiring follow-up</p>
    </div>
    <div style="display:flex;gap:7px;margin-top:10px">
      <div class="badge ca-filter active-filter" data-f="open" onclick="caFilter(this)" style="cursor:pointer;background:var(--gold);color:var(--deep);border-color:var(--gold)">Open</div>
      <div class="badge ca-filter" data-f="inprogress" onclick="caFilter(this)" style="cursor:pointer">In Progress</div>
      <div class="badge ca-filter" data-f="closed" onclick="caFilter(this)" style="cursor:pointer">Closed</div>
      <div class="badge ca-filter" data-f="all" onclick="caFilter(this)" style="cursor:pointer">All</div>
    </div>
  </div>

  <div class="syncbar">
    <div class="sync-l"><div class="bdot g"></div><span>Live from Firebase</span></div>
    <div class="sync-r" id="ca-count">Loading...</div>
  </div>

  <div class="tiles">

    <!-- Actions list -->
    <div style="display:flex;flex-direction:column;gap:8px" id="ca-list">

      <!-- OVERDUE -->
      <div class="fcard" style="border-color:rgba(184,50,50,.3)" id="ca-1">
        <div style="background:#FAEBEB;padding:10px 14px;display:flex;align-items:center;justify-content:space-between">
          <div style="display:flex;align-items:center;gap:7px">
            <div style="width:7px;height:7px;border-radius:50%;background:#B83232"></div>
            <span style="font-size:10px;font-weight:600;color:#B83232;text-transform:uppercase;letter-spacing:.07em">Overdue</span>
          </div>
          <span style="font-size:10px;color:#C06060">Due 8 Apr — 3 days ago</span>
        </div>
        <div class="fcard-body" style="padding:12px 14px">
          <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:4px">Resolve unsecured excavation — Site A</div>
          <div style="font-size:11px;color:var(--muted);margin-bottom:10px">Source: Hazard report HAZ-2604-01 · Assigned to: Site Supervisor</div>
          <div style="display:flex;gap:7px">
            <button onclick="caUpdateStatus('ca-1','inprogress')" style="flex:1;padding:8px;border-radius:8px;border:1px solid var(--border);background:#fff;font-size:11px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif">In Progress</button>
            <button onclick="caUpdateStatus('ca-1','closed')" style="flex:1;padding:8px;border-radius:8px;border:none;background:var(--mid);color:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">Mark Complete</button>
          </div>
        </div>
      </div>

      <!-- OVERDUE 2 -->
      <div class="fcard" style="border-color:rgba(184,50,50,.3)" id="ca-2">
        <div style="background:#FAEBEB;padding:10px 14px;display:flex;align-items:center;justify-content:space-between">
          <div style="display:flex;align-items:center;gap:7px">
            <div style="width:7px;height:7px;border-radius:50%;background:#B83232"></div>
            <span style="font-size:10px;font-weight:600;color:#B83232;text-transform:uppercase;letter-spacing:.07em">Overdue</span>
          </div>
          <span style="font-size:10px;color:#C06060">Due 5 Apr — 6 days ago</span>
        </div>
        <div class="fcard-body" style="padding:12px 14px">
          <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:4px">Close out Excavator EX-02 hydraulic fault</div>
          <div style="font-size:11px;color:var(--muted);margin-bottom:10px">Source: Plant pre-start · Assigned to: Site Supervisor</div>
          <div style="display:flex;gap:7px">
            <button onclick="caUpdateStatus('ca-2','inprogress')" style="flex:1;padding:8px;border-radius:8px;border:1px solid var(--border);background:#fff;font-size:11px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif">In Progress</button>
            <button onclick="caUpdateStatus('ca-2','closed')" style="flex:1;padding:8px;border-radius:8px;border:none;background:var(--mid);color:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">Mark Complete</button>
          </div>
        </div>
      </div>

      <!-- OPEN (due soon) -->
      <div class="fcard" style="border-color:rgba(184,150,12,.3)" id="ca-3">
        <div style="background:#FDF8E8;padding:10px 14px;display:flex;align-items:center;justify-content:space-between">
          <div style="display:flex;align-items:center;gap:7px">
            <div style="width:7px;height:7px;border-radius:50%;background:#B8960C"></div>
            <span style="font-size:10px;font-weight:600;color:#B8960C;text-transform:uppercase;letter-spacing:.07em">Open — Due Soon</span>
          </div>
          <span style="font-size:10px;color:#A07020">Due 15 Apr — 4 days</span>
        </div>
        <div class="fcard-body" style="padding:12px 14px">
          <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:4px">Arrange HRWL renewal — Jake Ryan</div>
          <div style="font-size:11px;color:var(--muted);margin-bottom:10px">Source: Training matrix alert · Assigned to: Site Supervisor</div>
          <div style="display:flex;gap:7px">
            <button onclick="caUpdateStatus('ca-3','inprogress')" style="flex:1;padding:8px;border-radius:8px;border:1px solid var(--border);background:#fff;font-size:11px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif">In Progress</button>
            <button onclick="caUpdateStatus('ca-3','closed')" style="flex:1;padding:8px;border-radius:8px;border:none;background:var(--mid);color:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">Mark Complete</button>
          </div>
        </div>
      </div>

      <!-- OPEN -->
      <div class="fcard" id="ca-4">
        <div style="background:#E6F5ED;padding:10px 14px;display:flex;align-items:center;justify-content:space-between">
          <div style="display:flex;align-items:center;gap:7px">
            <div style="width:7px;height:7px;border-radius:50%;background:#1B6E3A"></div>
            <span style="font-size:10px;font-weight:600;color:#1B6E3A;text-transform:uppercase;letter-spacing:.07em">Open</span>
          </div>
          <span style="font-size:10px;color:var(--muted)">Due 20 Apr — 9 days</span>
        </div>
        <div class="fcard-body" style="padding:12px 14px">
          <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:4px">Add manual handling to next toolbox talk</div>
          <div style="font-size:11px;color:var(--muted);margin-bottom:10px">Source: Body injury map — lower back · Assigned to: Site Supervisor</div>
          <div style="display:flex;gap:7px">
            <button onclick="caUpdateStatus('ca-4','inprogress')" style="flex:1;padding:8px;border-radius:8px;border:1px solid var(--border);background:#fff;font-size:11px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif">In Progress</button>
            <button onclick="caUpdateStatus('ca-4','closed')" style="flex:1;padding:8px;border-radius:8px;border:none;background:var(--mid);color:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">Mark Complete</button>
          </div>
        </div>
      </div>

    </div>

    <!-- New Action Form (hidden by default) -->
    <div id="ca-new-form" style="display:none;background:var(--card);border-radius:var(--r);padding:15px;border:1.5px solid var(--deep)">
      <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:12px">New corrective action</div>
      <div class="fgroup" style="margin-bottom:10px">
        <label class="flabel">Description <span class="req">*</span></label>
        <input type="text" id="ca-new-desc" placeholder="What needs to be done?">
      </div>
      <div class="fgroup" style="margin-bottom:10px">
        <label class="flabel">Source</label>
        <select id="ca-new-source">
          <option value="">Select source...</option>
          <option>Incident report</option>
          <option>Hazard report</option>
          <option>Pre-start check</option>
          <option>Body injury map</option>
          <option>Training matrix</option>
          <option>Supervisor observation</option>
          <option>Site inspection</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
        <div class="fgroup">
          <label class="flabel">Assigned to</label>
          <input type="text" id="ca-new-assign" placeholder="Name or role">
        </div>
        <div class="fgroup">
          <label class="flabel">Due date</label>
          <input type="date" id="ca-new-due">
        </div>
      </div>
      <div class="fgroup" style="margin-bottom:12px">
        <label class="flabel">Priority</label>
        <select id="ca-new-priority">
          <option value="medium">Medium</option>
          <option value="high">High</option>
          <option value="critical">Critical</option>
          <option value="low">Low</option>
        </select>
      </div>
      <div style="display:flex;gap:8px">
        <button onclick="document.getElementById('ca-new-form').style.display='none'" style="flex:1;padding:12px;border-radius:10px;border:1px solid var(--border);background:#fff;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif">Cancel</button>
        <button onclick="saveNewAction()" style="flex:2;padding:12px;border-radius:10px;border:none;background:var(--deep);color:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif">Save Action</button>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════ SITE BROADCAST ═══ -->
<div id="screen-broadcast" class="screen">
  <div class="sb"></div>
  <div class="topbar" style="padding-bottom:14px">
    <div class="topbar-row">
      <button class="back-btn" onclick="goTo('screen-dash')"><svg viewBox="0 0 24 24" fill="none"><polyline points="15 18 9 12 15 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></button>
      <div class="tbar-logo" style="padding:2px 0"><img id="bc-logo" src="" alt="Slán Safety" style="height:44px;object-fit:contain;display:block"></div>
      <div style="width:36px"></div>
    </div>
    <div class="tbar-greeting" style="margin-top:10px">
      <h1>Site Broadcast</h1>
      <p id="bc-subtitle">Message all workers on site</p>
    </div>
  </div>

  <div class="fbody" style="gap:14px">

    <div class="fcard">
      <div class="fcard-hdr">Message</div>
      <div class="fcard-body" style="gap:12px">
        <div class="fgroup">
          <label class="flabel">Priority</label>
          <select id="bc-priority">
            <option value="normal">Normal — informational</option>
            <option value="urgent">Urgent — requires immediate attention</option>
            <option value="emergency">Emergency — stop work</option>
          </select>
        </div>
        <div class="fgroup">
          <label class="flabel">Message <span class="req">*</span></label>
          <textarea id="bc-message" rows="5" placeholder="Type your message to all workers on site..." style="font-size:14px;resize:none"></textarea>
        </div>
      </div>
    </div>

    <button onclick="sendBroadcast()" class="submit-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:19px;height:19px"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
      Send to all workers on site
    </button>

    <!-- Recent broadcasts -->
    <div class="fcard">
      <div class="fcard-hdr">Recent broadcasts</div>
      <div id="bc-history-list" style="padding:0"></div>
    </div>

  </div>
</div>

<!-- ═══════════════════ WORKER CONTACTS ═══ -->
<div id="screen-worker-contacts" class="screen">
  <div class="sb"></div>
  <div class="topbar" style="padding-bottom:14px">
    <div class="topbar-row">
      <button class="back-btn" onclick="goTo('screen-dash')"><svg viewBox="0 0 24 24" fill="none"><polyline points="15 18 9 12 15 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></button>
      <div class="tbar-logo" style="padding:2px 0"><img id="wc-logo" src="" alt="Slán Safety" style="height:44px;object-fit:contain;display:block"></div>
      <div style="width:36px"></div>
    </div>
    <div class="tbar-greeting" style="margin-top:10px">
      <h1>Worker Contacts</h1>
      <p id="wc-subtitle">On site now — tap to call</p>
    </div>
  </div>

  <div class="syncbar">
    <div class="sync-l"><div class="bdot g"></div><span>Live from sign-in records</span></div>
    <div class="sync-r" id="wc-count">Loading...</div>
  </div>

  <div class="tiles">

    <!-- Search bar -->
    <div style="position:relative">
      <input type="text" id="wc-search" oninput="wcSearch()" placeholder="Search workers..." style="width:100%;padding:11px 13px 11px 38px;border:1.5px solid var(--border);border-radius:var(--rs);font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);background:#fff;outline:none">
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" style="width:16px;height:16px;position:absolute;left:12px;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    </div>

    <!-- On site -->
    <div style="background:var(--card);border-radius:var(--r);border:1px solid var(--border);overflow:hidden">
      <div style="background:var(--deep);padding:10px 14px;font-size:10px;font-weight:600;color:var(--gold);letter-spacing:.08em;text-transform:uppercase">Currently on site — tap for details</div>
      <div id="wc-onsite-list" style="padding:0"></div>
    </div>

    <!-- Off site / not signed in -->
    <div style="background:var(--card);border-radius:var(--r);border:1px solid var(--border);overflow:hidden">
      <div style="background:#4B5563;padding:10px 14px;font-size:10px;font-weight:600;color:#D1D5DB;letter-spacing:.08em;text-transform:uppercase">Off site today — tap for details</div>
      <div id="wc-all-list" style="padding:0"></div>
    </div>

  </div>
</div>>
