          <rect class="an-zone" data-l="Left Upper Arm (Rear)" data-n="0" x="156" y="80" width="34" height="70" rx="10" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Right Upper Arm (Rear)" data-n="0" x="10" y="80" width="34" height="70" rx="10" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Left Forearm (Rear)" data-n="1" x="164" y="152" width="30" height="60" rx="10" fill="#2D6A45" fill-opacity=".35" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Right Forearm (Rear)" data-n="0" x="6" y="152" width="30" height="60" rx="10" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <ellipse class="an-zone" data-l="Left Hand (Rear)" data-n="0" cx="180" cy="242" rx="18" ry="28" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <ellipse class="an-zone" data-l="Right Hand (Rear)" data-n="0" cx="20" cy="242" rx="18" ry="28" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Left Hamstring" data-n="4" x="110" y="202" width="44" height="68" rx="10" fill="#B8960C" fill-opacity=".6" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Right Hamstring" data-n="2" x="46" y="202" width="44" height="68" rx="10" fill="#2D6A45" fill-opacity=".35" stroke="#1B3A2D" stroke-width="1"/>
          <ellipse class="an-zone" data-l="Left Knee (Rear)" data-n="1" cx="134" cy="288" rx="20" ry="14" fill="#2D6A45" fill-opacity=".35" stroke="#1B3A2D" stroke-width="1"/>
          <ellipse class="an-zone" data-l="Right Knee (Rear)" data-n="0" cx="66" cy="288" rx="20" ry="14" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Left Calf" data-n="2" x="114" y="304" width="40" height="62" rx="10" fill="#2D6A45" fill-opacity=".38" stroke="#1B3A2D" stroke-width="1"/>
          <rect class="an-zone" data-l="Right Calf" data-n="0" x="46" y="304" width="40" height="62" rx="10" fill="rgba(27,58,45,.1)" stroke="#1B3A2D" stroke-width="1"/>
          <text x="164" y="445" font-size="10" fill="#9FC4AE" font-family="sans-serif" font-weight="600">L</text>
          <text x="24" y="445" font-size="10" fill="#9FC4AE" font-family="sans-serif" font-weight="600">R</text>
        </svg>
        </div>
<div id="an-bm-panel" style="display:none;margin-top:12px;background:#F8FAF9;border-radius:10px;border:1.5px solid var(--deep);padding:13px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div>
            <div id="an-bm-name" style="font-size:14px;font-weight:600;color:var(--text)"></div>
            <div id="an-bm-count" style="font-size:11px;color:var(--muted);margin-top:2px"></div>
          </div>
          <button onclick="document.getElementById('an-bm-panel').style.display='none'" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:20px;line-height:1;padding:0 2px">x</button>
        </div>
        <div id="an-bm-hist" style="margin-top:8px;display:flex;flex-direction:column;gap:5px"></div>
      </div>
    </div>
      </div>
    </div>


    <!-- Director: Contact + Scorecard as matching tiles -->

    <!-- Contact Slán + Scorecard — matching standard tiles -->
    <div id="an-dir-tiles" style="display:none;grid-template-columns:1fr 1fr;gap:10px">
      <div id="an-contact-btn" class="tile" style="display:none" onclick="goToContactSlan()">
        <div class="tile-icon ic-blue"><svg viewBox="0 0 24 24" fill="none" stroke="#1C5AAD" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <div class="tile-name">Contact Slán</div>
        <div class="tile-sub">Message WHS provider</div>
      </div>
      <div id="an-scorecard-btn" class="tile" style="display:none" onclick="goToScorecard()">
        <div class="tile-icon ic-amber"><svg viewBox="0 0 24 24" fill="none" stroke="#906500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
        <div class="tile-name">Scorecard</div>
        <div class="tile-sub">Monthly RAG report</div>
